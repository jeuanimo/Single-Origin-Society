# ---------------------------------------------------------------------------
# Single Origin Society – Environment Variables
# Copy to .env and fill in real values before running.
# 
# For Render deployment, these variables are automatically populated
# from render.yaml and Render environment configuration.
# ---------------------------------------------------------------------------

# Django core
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# Local development: use Docker Compose or local PostgreSQL
# Render: These are auto-populated from render.yaml
DB_ENGINE=django.db.backends.postgresql
DB_NAME=sos_db
DB_USER=sos_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Stripe
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Configuration
# Option 1: SendGrid (recommended for production)
# Get key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Standard SMTP (Gmail, Mailgun, etc.)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@singleoriginsociety.com
SERVER_EMAIL=admin@singleoriginsociety.com
